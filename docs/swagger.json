        "app.CheckoutParams": {
            "type": "object",
            "properties": {
                "address": {
                    "$ref": "#/definitions/app.Address"
                },
                "cancelURL": {
                    "type": "string"
                },
                "email": {
                    "type": "string"
                },
                "firstName": {
                    "type": "string"
                },
                "lastName": {
                    "type": "string"
                },
                "planID": {
                    "type": "string"
                },
                "stripeSubscriptionID": {
                    "type": "string"
                },
                "successURL": {
                    "type": "string"
                },
                "timezone": {
                    "type": "string"
                },
                "userID": {
                    "type": "string"
                }
            }
        },
        "command.SetupFreeTierParams": {
            "type": "object",
            "properties": {
                "address": {
                    "$ref": "#/definitions/app.Address"
                },
                "country": {
                    "type": "string"
                },
                "email": {
                    "type": "string"
                },
                "firstName": {
                    "type": "string"
                },
                "lastName": {
                    "type": "string"
                },
                "timezone": {
                    "type": "string"
                },
                "userId": {
                    "type": "string"
                }
            }
        }
    }
}