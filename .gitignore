# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib
*.log
*.air.toml

# Test binary, built with `go test -c`
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Dependency directories (only if you don't want to vendor your dependencies)
# vendor/
temp

# Go workspace files
go.work
go.work.sum

# Environment files
.env

# Editor/IDE specific files (Optional, or move to global gitignore)
.idea/
.vscode/
*.swp
